---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;
const pageSuffix = page.currentPage > 1 ? ` | 第 ${page.currentPage} 页` : "";
const metaDescription = `浏览 Ermaozi 中与“${tagName}”相关的文章，第 ${page.currentPage} 页，共 ${page.lastPage} 页；查看独立实测、长期观察、风险记录与网络工具教程。`;
---

<Layout
  title={`标签：${tagName}${pageSuffix} | ${SITE.title}`}
  description={metaDescription}
>
  <Header />
  <Main
    pageTitle={[`标签：`, `${tagName}`]}
    titleTransition={tag}
    pageDesc={`与“${tagName}”相关的全部文章。`}
  >
    <h1 slot="title" transition:name={tag}>{`标签：${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
